# Запрет прямого доступа к PHP-файлам из других скриптов
Options -Indexes

# Разрешить только index.php, всё остальное запрещено
<FilesMatch "^(?!index\.php$).*$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Защита от брутфорса: ограничить методы
<LimitExcept GET POST>
    Deny from all
</LimitExcept>
